# Local credentials for scripts and tests. Copy to `.env.local` and fill in
# from 1Password (manually via the GUI, or run `scripts/load-1p-creds.sh
# > .env.local` to pull everything in one shot).
#
# `.env.local` is gitignored. direnv loads it automatically on cd into the
# repo — see .envrc.

# Local dev PocketBase admin (used by `npm run pb:seed-admins`).
# 1Password: op://Private/localhost-dev-admin-user
PB_DEV_ADMIN_EMAIL=
PB_DEV_ADMIN_PASSWORD=

# Staging deploy + seeding. Used by:
#   web/npm run test:smoke:staging
#   scripts/seed-staging-smoke-users.sh
#   scripts/seed-prod-bootstrap.sh rivcomocktrial-staging
# 1Password admin: op://Private/rivcomocktrial-staging-admin
# 1Password coach: op://Private/rivcomocktrial-staging-user
STAGING_BASE_URL=https://rivcomocktrial-staging.fly.dev
STAGING_ADMIN_EMAIL=
STAGING_ADMIN_PASSWORD=
STAGING_COACH_EMAIL=
STAGING_COACH_PASSWORD=

# Production deploy. Used by:
#   web/npm run test:smoke:prod
#   scripts/seed-prod-bootstrap.sh rivcomocktrial
# 1Password: op://Private/rivcomocktrial
PROD_BASE_URL=https://rivcomocktrial.org
PROD_ADMIN_EMAIL=
PROD_ADMIN_PASSWORD=
